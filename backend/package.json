{
  "name": "commodities-trading-backend",
  "version": "1.0.0",
  "description": "Backend for commodities trading ecosystem",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "migrate": "npm run build && node dist/migrations/run.js",
    "lint": "eslint src --ext .ts",
    "seed": "ts-node src/seeders/index.ts"
  },
  "keywords": ["commodities", "trading", "real-time"],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "pg": "^8.10.0",
    "redis": "^4.6.11",
    "bull": "^4.11.4",
    "socket.io": "^4.7.2",
    "axios": "^1.6.2",
    "node-fetch": "^2.7.0",
    "cheerio": "^1.0.0-rc.12",
    "nodemailer": "^6.9.7",
    "winston": "^3.11.0",
    "joi": "^17.11.0",
    "bcrypt": "^5.1.1",
    "jsonwebtoken": "^9.1.2",
    "date-fns": "^2.30.0",
    "lodash": "^4.17.21",
    "uuid": "^9.0.1",
    "qs": "^6.11.2",
    "xml2js": "^0.6.2",
    "csv-parse": "^5.5.0",
    "cron": "^3.1.6"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.6",
    "@types/jest": "^29.5.11",
    "typescript": "^5.3.3",
    "ts-node-dev": "^2.0.0",
    "ts-node": "^10.9.2",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "eslint": "^8.56.0",
    "@typescript-eslint/eslint-plugin": "^6.17.0",
    "@typescript-eslint/parser": "^6.17.0"
  }
}
